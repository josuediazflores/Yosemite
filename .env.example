# Yosemite Field Monitor — Phase 2 keys. All free, no billing attached.
# Copy to .env (gitignored), fill in, restart `npm run dev`.
# Each module sleeps until its key lands here; the app runs fine without them.

# NPS Data API — https://www.nps.gov/subjects/developer/get-started.htm
NPS_API_KEY=

# NASA FIRMS MAP_KEY — https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# AirNow — https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=

# eBird — https://ebird.org/api/keygen
EBIRD_API_KEY=
